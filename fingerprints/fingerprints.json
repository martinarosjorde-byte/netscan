{
  "metadata": {
    "name": "NetScan Fingerprint Intelligence Database",
    "engine_version": "3.0",
    "schema_version": "3.0",
    "last_updated": "2026-03-01",
    "author": "Humbug Software",
    "description": "Weighted multi-signal fingerprint database for NetScan Learning Engine 3.0."
  },

  "schema_documentation": {
    "description": "Each fingerprint defines weighted detection signals. Scoring is cumulative. Strong signals are required for match unless explicitly overridden.",

    "weights": {
      "strong": "High confidence indicators such as unique HTTP titles, SSL CN matches, banner strings.",
      "medium": "Supporting indicators such as HTTP server header, MAC vendor, hostname pattern.",
      "weak": "Low confidence indicators such as port presence."
    },

    "signal_types": {
      "http.title_contains": "Substring match inside HTML title.",
      "http.body_contains": "Substring match inside HTTP body preview.",
      "http.header_contains": "Substring match in aggregated HTTP headers.",
      "http.server_contains": "Match inside HTTP Server header.",
      "http.cookie_contains": "Match inside Set-Cookie headers.",

      "ssl.cert_common_name_contains": "Substring match in certificate common name.",
      "ssl.cert_common_name_equals": "Exact match of certificate common name.",
      "ssl.cert_issuer_contains": "Substring match in certificate issuer.",
      "ssl.cert_san_contains": "Substring match in certificate SAN list.",
      "ssl.tls_error_contains": "TLS handshake error message contains substring.",

      "ssh.banner_contains": "Substring match in SSH banner.",
      "smtp.banner_contains": "Substring match in SMTP banner.",
      "ftp.banner_contains": "Substring match in FTP banner.",
      "pop3.banner_contains": "Substring match in POP3 banner.",
      "imap.banner_contains": "Substring match in IMAP banner.",

      "device.mac_vendor_contains": "Match inside MAC vendor string.",
      "device.hostname_contains": "Match inside resolved hostname.",

      "misc.favicon_hashes": "MMH3 hash of /favicon.ico.",
      "ports": "Presence of any of the listed ports."
    },

    "negative": "If matched, fingerprint is invalidated or penalized."
  },

  "fingerprints": [

