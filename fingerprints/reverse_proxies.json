    {
      "id": "fp_traefik_default_cert",
      "name": "Traefik Reverse Proxy (Default Certificate)",
      "category": "Reverse Proxy",
      "os_guess": "Linux",
      "priority": 85,
      "signals": {
        "strong": {
          "ssl": {
            "cert_common_name_contains": ["traefik default cert"],
            "cert_issuer_contains": ["traefik default cert"]
          }
        },
        "medium": {
          "ssl": {
            "cert_san_contains": [".traefik.default"]
          }
        },
        "weak": {
          "ports": [443, 8443]
        }
      }
    },
